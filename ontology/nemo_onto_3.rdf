        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#ScoringFunction"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#hasSource -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#hasSource">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#DataSource"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#mapsToFeature -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#mapsToFeature">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#RepresentationFeature"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#measuredWithinBuffer -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#measuredWithinBuffer">
