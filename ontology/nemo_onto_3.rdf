    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#composedOf -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#composedOf">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#CompositeMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:label>composed of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#hasMeasurementScale -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#hasMeasurementScale">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#MeasurementScale"/>
        <owl:propertyDisjointWith rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#hasScoringFunction"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#hasScoringFunction -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#hasScoringFunction">
