<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ebikecityevaluationtool.com/ontology/nemo#"
     xml:base="http://www.ebikecityevaluationtool.com/ontology/nemo"
     xmlns:ns1="http://ainf.aau.at/ontodebug#"
     xmlns:ns2="http://www.ontology-of-units-of-measure.org/resource/om-2/"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:geo="http://www.opengis.net/ont/geosparql#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo">
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>aggregatedOn Range AggregationFeature</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>CompositeMetric SubClassOf AggregationFeature</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>scores Range WeightingSystem</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>usedIn Range EvaluationCriteria</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>ContextualMetric SubClassOf EvaluationCriteria</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>Edge SubClassOf MeasurementScale</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>hasSource Range DataSource</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>Node SubClassOf AggregationFeature</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>nominal Type MeasurementScale</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>hasWeightingSystem Range ScoringSystem</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>measures Range EvaluationCriteria</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>measuredWithinBuffer Domain EvaluationMetric</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>hasSource Domain EvaluationCriteria</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ns1:type>
            </rdf:Description>
        </ns1:testCase>
        <ns1:testCase>
            <rdf:Description>
                <ns1:axiom>usedIn Range EvaluationMethod</ns1:axiom>
                <ns1:type rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ns1:type>
            </rdf:Description>
        </ns1:testCase>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ainf.aau.at/ontodebug#axiom -->

    <owl:AnnotationProperty rdf:about="http://ainf.aau.at/ontodebug#axiom">
        <rdfs:subPropertyOf rdf:resource="http://ainf.aau.at/ontodebug#testCase"/>
    </owl:AnnotationProperty>
    


    <!-- http://ainf.aau.at/ontodebug#testCase -->

    <owl:AnnotationProperty rdf:about="http://ainf.aau.at/ontodebug#testCase"/>
    


    <!-- http://ainf.aau.at/ontodebug#type -->

    <owl:AnnotationProperty rdf:about="http://ainf.aau.at/ontodebug#type">
        <rdfs:subPropertyOf rdf:resource="http://ainf.aau.at/ontodebug#testCase"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/LaTeXCommand -->

    <owl:AnnotationProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/LaTeXCommand"/>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/LaTeXSymbol -->

    <owl:AnnotationProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/LaTeXSymbol"/>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/alternativeLabel -->

