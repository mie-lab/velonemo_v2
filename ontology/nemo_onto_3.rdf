    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/longcomment -->

    <owl:AnnotationProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/longcomment"/>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/symbol -->

    <owl:AnnotationProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/symbol"/>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/unofficialAbbreviation -->

    <owl:AnnotationProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/unofficialAbbreviation"/>
    


    <!-- 
