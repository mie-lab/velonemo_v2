        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMethod"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#weightedBy -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#weightedBy">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Weight"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/hasAggregateFunction -->

    <owl:ObjectProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/hasAggregateFunction">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Function"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/hasUnit -->

    <owl:ObjectProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/hasUnit">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Measure"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit"/>
        <rdfs:label xml:lang="en">has unit</rdfs:label>
        <rdfs:label xml:lang="ja">単位を持つ</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/hasValue -->

    <owl:ObjectProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/hasValue">
        <rdfs:domain rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Measure"/>
        <rdfs:label xml:lang="en">has value</rdfs:label>
        <rdfs:label xml:lang="ja">値を持つ</rdfs:label>
    </owl:ObjectProperty>
    


