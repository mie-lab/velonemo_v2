    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#nominal -->

    <owl:NamedIndividual rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#nominal">
        <rdf:type rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#MeasurementScale"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#ordinal -->

    <owl:NamedIndividual rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#ordinal">
        <rdf:type rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#MeasurementScale"/>
    </owl:NamedIndividual>
    


