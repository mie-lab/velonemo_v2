    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/Illuminance">
        <ns2:alternativeLabel xml:lang="en">illumination</ns2:alternativeLabel>
        <ns2:alternativeSymbol>Φ_v</ns2:alternativeSymbol>
        <ns2:symbol>Φ</ns2:symbol>
        <rdfs:comment xml:lang="en">Illuminance is the total luminous flux incident on a surface per unit area.</rdfs:comment>
        <rdfs:label xml:lang="en">illuminance</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/Velocity">
        <ns2:alternativeSymbol>v</ns2:alternativeSymbol>
        <ns2:alternativeSymbol>w</ns2:alternativeSymbol>
        <ns2:symbol>u</ns2:symbol>
        <rdfs:comment xml:lang="en">Velocity is the rate of change of position.</rdfs:comment>
        <rdfs:label xml:lang="nl">snelheid (vector)</rdfs:label>
        <rdfs:label xml:lang="en">velocity</rdfs:label>
    </rdf:Description>



    <!-- ================= VeloNEMO v2 axes (D-027/D-029) ================= -->


    <!-- new classes -->

    <owl:Class rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim">
        <rdfs:comment>A reified metric-to-criterion assertion posed by a method; carries modality and confidence (D-004).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationPerspective">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment>objective (measured) vs perceived (experienced) (D-003).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#DataModality">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment>how a metric is measured; each modality is ofPerspective objective or perceived.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#StudyArea">
        <rdfs:comment>the city/region a method was applied to (D-027); distinct from RepresentationFeature.</rdfs:comment>
    </owl:Class>


    <!-- align the metric aggregation unit to GeoSPARQL -->

    <owl:Class rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#RepresentationFeature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    </owl:Class>


    <!-- object properties -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#posesClaim">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMethod"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#onMetric">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#onCriterion">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationCriterion"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#viaModality">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#DataModality"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#hasDataModality">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#DataModality"/>
        <rdfs:comment>the metric's typical measurement method</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#ofPerspective">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#DataModality"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationPerspective"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#hasStudyArea">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMethod"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#StudyArea"/>
    </owl:ObjectProperty>


    <!-- data properties -->

    <owl:DatatypeProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#publicationYear">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#studyAreaName">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#StudyArea"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#country">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#StudyArea"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#extractionConfidence">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#Claim"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>


