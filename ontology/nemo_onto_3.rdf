        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Distance"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#measures -->

    <owl:ObjectProperty rdf:about="http://www.ebikecityevaluationtool.com/ontology/nemo#measures">
        <rdfs:domain rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationMetric"/>
        <rdfs:range rdf:resource="http://www.ebikecityevaluationtool.com/ontology/nemo#EvaluationCriterion"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ebikecityevaluationtool.com/ontology/nemo#usedIn -->

